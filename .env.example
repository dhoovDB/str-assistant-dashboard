# Supabase project credentials.
# Get these from Supabase dashboard → Settings → API.
# SUPABASE_URL is the "Project URL"; SUPABASE_KEY is the "anon public" key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# Which property this dashboard instance represents.
# v1: URL-based property routing is deferred to Task 9, so this is set per-deployment.
# Use a hard-to-guess value (e.g. a UUID) — security comes from URL/env secrecy.
PROPERTY_ID=replace-me-with-a-uuid

# NOTE: production on Cloudflare Workers does NOT read .env at runtime.
# Set production secrets via `wrangler secret put SUPABASE_URL` (and similar)
# or in the Cloudflare dashboard. Tracked in ROADMAP decision log 2026-05-11.
